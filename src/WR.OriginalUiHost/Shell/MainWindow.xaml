<Window x:Class="WR.OriginalUiHost.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="WRobot"
        Width="780"
        Height="560"
        MinWidth="780"
        MinHeight="560"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource AppWindowBrush}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="156" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="{DynamicResource AppChromeBrush}"
                BorderBrush="{DynamicResource AppBorderBrush}"
                BorderThickness="0,0,1,0">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top"
                            Margin="16,18,16,14">
                    <TextBlock Text="WRobot"
                               FontSize="21"
                               FontWeight="SemiBold" />
                </StackPanel>

                <ListBox ItemsSource="{Binding Pages}"
                         SelectedItem="{Binding SelectedPage}"
                         BorderThickness="0"
                         Background="Transparent"
                         Foreground="{DynamicResource AppTextBrush}"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="MinHeight" Value="44" />
                            <Setter Property="Padding" Value="14,8" />
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource AppPanelAltBrush}" />
                                    <Setter Property="Foreground" Value="{DynamicResource AppSelectionTextBrush}" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Text="{Binding Title}"
                                           FontSize="14"
                                           FontWeight="SemiBold" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1"
              Background="{DynamicResource AppWindowBrush}">
            <ContentControl Content="{Binding SelectedPage.Content}" />
        </Grid>
    </Grid>
</Window>
