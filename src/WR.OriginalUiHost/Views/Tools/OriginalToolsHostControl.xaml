<UserControl x:Class="WR.OriginalUiHost.OriginalToolsHostControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource AppWindowBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Margin="10,8,10,0"
                Padding="0,0,0,8"
                Background="Transparent"
                BorderBrush="{DynamicResource AppBorderBrush}"
                BorderThickness="0,0,0,1">
            <DockPanel LastChildFill="False">
                <TextBlock DockPanel.Dock="Left"
                           Margin="0,6,12,0"
                           VerticalAlignment="Center"
                           Text="语言"
                           FontSize="12"
                           Foreground="{DynamicResource AppMutedTextBrush}" />
                <ComboBox x:Name="LanguageComboBox"
                          DockPanel.Dock="Left"
                          Margin="0,0,16,0"
                          Width="180"
                          DisplayMemberPath="DisplayName"
                          SelectionChanged="LanguageComboBox_OnSelectionChanged" />
                <TextBlock DockPanel.Dock="Left"
                           Margin="0,6,12,0"
                           VerticalAlignment="Center"
                           Text="主题"
                           FontSize="12"
                           Foreground="{DynamicResource AppMutedTextBrush}" />
                <ComboBox x:Name="ThemeComboBox"
                          DockPanel.Dock="Left"
                          Width="120"
                          DisplayMemberPath="DisplayName"
                          SelectionChanged="ThemeComboBox_OnSelectionChanged" />
            </DockPanel>
        </Border>

        <ContentControl x:Name="OriginalContentHost"
                        Grid.Row="1" />

        <Border x:Name="LoadingPanel"
                Grid.Row="1"
                Visibility="Collapsed"
                Margin="18"
                Padding="16"
                Background="{DynamicResource AppPanelBrush}"
                BorderBrush="{DynamicResource AppBorderBrush}"
                BorderThickness="1">
            <StackPanel>
                <TextBlock Text="工具页初始化中"
                           FontSize="22"
                           FontWeight="SemiBold" />
                <TextBlock x:Name="LoadingText"
                           Margin="0,12,0,0"
                           Text="正在加载原版工具控件..."
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource AppMutedTextBrush}"
                           FontSize="12" />
            </StackPanel>
        </Border>

        <Border x:Name="FailurePanel"
                Grid.Row="1"
                Visibility="Collapsed"
                Margin="18"
                Padding="16"
                Background="{DynamicResource AppPanelBrush}"
                BorderBrush="{DynamicResource AppBorderBrush}"
                BorderThickness="1">
            <StackPanel>
                <TextBlock Text="工具页加载失败"
                           FontSize="22"
                           FontWeight="SemiBold" />
                <ScrollViewer Margin="0,12,0,0"
                              VerticalScrollBarVisibility="Auto">
                    <TextBox x:Name="FailureText"
                             IsReadOnly="True"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             BorderThickness="0"
                             Background="{DynamicResource AppSurfaceBrush}"
                             Foreground="{DynamicResource AppDangerTextBrush}"
                             FontFamily="Consolas"
                             FontSize="12" />
                </ScrollViewer>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
