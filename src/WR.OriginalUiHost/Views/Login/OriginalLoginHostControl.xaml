<UserControl x:Class="WR.OriginalUiHost.OriginalLoginHostControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource AppWindowBrush}">
    <Grid>
        <ContentControl x:Name="OriginalLoginContent" />
        <Border x:Name="FailurePanel"
                Visibility="Collapsed"
                Padding="16"
                Background="{DynamicResource AppPanelBrush}"
                BorderBrush="{DynamicResource AppBorderBrush}"
                BorderThickness="1">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="入口页加载失败"
                           Foreground="{DynamicResource AppDangerTextBrush}"
                           FontSize="18"
                           FontWeight="SemiBold" />
                <TextBlock x:Name="FailureText"
                           Margin="0,10,0,0"
                           Foreground="{DynamicResource AppTextBrush}"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
