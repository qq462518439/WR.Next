<UserControl x:Class="WR.OriginalUiHost.OriginalPluginsHostControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource AppWindowBrush}">
    <Grid>
        <ContentControl x:Name="OriginalContentHost" />

        <Border x:Name="FailurePanel"
                Visibility="Collapsed"
                Margin="18"
                Padding="16"
                Background="{DynamicResource AppPanelBrush}"
                BorderBrush="{DynamicResource AppBorderBrush}"
                BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Text="插件页加载失败"
                           FontSize="22"
                           FontWeight="SemiBold" />

                <ScrollViewer Grid.Row="1"
                              Margin="0,12,0,0"
                              VerticalScrollBarVisibility="Auto">
                    <TextBox x:Name="FailureText"
                             IsReadOnly="True"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             BorderThickness="0"
                             Background="{DynamicResource AppSurfaceBrush}"
                             Foreground="{DynamicResource AppDangerTextBrush}"
                             FontFamily="Consolas"
                             FontSize="12" />
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>
