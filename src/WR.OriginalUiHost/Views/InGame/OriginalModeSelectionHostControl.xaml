<UserControl x:Class="WR.OriginalUiHost.OriginalModeSelectionHostControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource AppWindowBrush}">
    <Grid>
        <ContentControl x:Name="ModeSelectionContent" />

        <Border x:Name="FailurePanel"
                Visibility="Collapsed"
                Margin="18"
                Padding="16"
                Background="{DynamicResource AppPanelBrush}"
                BorderBrush="{DynamicResource AppBorderStrongBrush}"
                BorderThickness="1">
            <StackPanel>
                <TextBlock Text="模式选择页加载失败"
                           FontSize="20"
                           FontWeight="SemiBold" />
                <ScrollViewer Margin="0,12,0,0"
                              VerticalScrollBarVisibility="Auto">
                    <TextBox x:Name="FailureText"
                             IsReadOnly="True"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             BorderThickness="0"
                             Background="{DynamicResource AppSurfaceBrush}"
                             Foreground="{DynamicResource AppDangerTextBrush}"
                             FontFamily="Consolas"
                             FontSize="12" />
                </ScrollViewer>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
