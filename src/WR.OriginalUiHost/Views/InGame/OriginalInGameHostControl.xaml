<UserControl x:Class="WR.OriginalUiHost.OriginalInGameHostControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource AppWindowBrush}">
    <Grid>
        <ContentControl x:Name="OriginalContentHost" />

        <Border x:Name="FailurePanel"
                Visibility="Collapsed"
                Margin="18"
                Padding="16"
                Background="{DynamicResource AppPanelBrush}"
                BorderBrush="{DynamicResource AppBorderBrush}"
                BorderThickness="1">
            <StackPanel>
                <TextBlock x:Name="StatusText"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Text="游戏中页未就绪" />
                <WrapPanel Margin="0,12,0,0">
                    <Button Content="启动产品"
                            Margin="0,0,8,8"
                            Padding="12,4"
                            Click="OnStartProductClicked" />
                    <Button Content="开始战斗"
                            Margin="0,0,8,8"
                            Padding="12,4"
                            Click="OnStartFightClicked" />
                    <Button Content="朝向目标"
                            Margin="0,0,8,8"
                            Padding="12,4"
                            Click="OnFaceTargetClicked" />
                    <Button Content="跟近一次"
                            Margin="0,0,8,8"
                            Padding="12,4"
                            Click="OnApproachTargetClicked" />
                    <Button Content="交互目标"
                            Margin="0,0,8,8"
                            Padding="12,4"
                            Click="OnInteractTargetClicked" />
                    <Button Content="目标连测"
                            Margin="0,0,8,8"
                            Padding="12,4"
                            Click="OnTargetSequenceClicked" />
                    <Button Content="战斗连测"
                            Margin="0,0,8,8"
                            Padding="12,4"
                            Click="OnBattleSequenceClicked" />
                    <Button Content="暂停产品"
                            Margin="0,0,8,8"
                            Padding="12,4"
                            Click="OnPauseProductClicked" />
                    <Button Content="恢复产品"
                            Margin="0,0,8,8"
                            Padding="12,4"
                            Click="OnResumeProductClicked" />
                    <Button Content="停止产品"
                            Margin="0,0,8,8"
                            Padding="12,4"
                            Click="OnStopProductClicked" />
                    <Button Content="停止移动"
                            Margin="0,0,8,8"
                            Padding="12,4"
                            Click="OnStopMoveClicked" />
                    <Button Content="停止战斗"
                            Margin="0,0,8,8"
                            Padding="12,4"
                            Click="OnStopFightClicked" />
                    <Button Content="刷新状态"
                            Margin="0,0,8,8"
                            Padding="12,4"
                            Click="OnRefreshClicked" />
                </WrapPanel>
                <TextBlock x:Name="ProductStateText"
                           Margin="0,8,0,0"
                           Foreground="{DynamicResource AppMutedTextBrush}"
                           TextWrapping="Wrap"
                           Text="产品状态: -" />
                <TextBlock x:Name="CombatStateText"
                           Margin="0,8,0,0"
                           Foreground="{DynamicResource AppMutedTextBrush}"
                           TextWrapping="Wrap"
                           Text="战斗状态: -" />
                <TextBlock x:Name="TargetStateText"
                           Margin="0,8,0,0"
                           Foreground="{DynamicResource AppMutedTextBrush}"
                           TextWrapping="Wrap"
                           Text="目标状态: -" />
                <TextBlock x:Name="ActionSummaryText"
                           Margin="0,8,0,0"
                           Foreground="{DynamicResource AppMutedTextBrush}"
                           TextWrapping="Wrap"
                           Text="动作摘要: -" />
                <TextBlock x:Name="ResultStateText"
                           Margin="0,8,0,0"
                           Foreground="{DynamicResource AppMutedTextBrush}"
                           TextWrapping="Wrap"
                           Text="结果判定: -" />
                <TextBlock x:Name="ActionDiagnosisText"
                           Margin="0,8,0,0"
                           Foreground="{DynamicResource AppMutedTextBrush}"
                           TextWrapping="Wrap"
                           Text="动作诊断: -" />
                <TextBlock x:Name="SequenceDiagnosisText"
                           Margin="0,8,0,0"
                           Foreground="{DynamicResource AppMutedTextBrush}"
                           TextWrapping="Wrap"
                           Text="分步诊断: -" />
                <TextBlock x:Name="DeltaStateText"
                           Margin="0,8,0,0"
                           Foreground="{DynamicResource AppMutedTextBrush}"
                           TextWrapping="Wrap"
                           Text="变化摘要: -" />
                <TextBlock x:Name="TrendStateText"
                           Margin="0,8,0,0"
                           Foreground="{DynamicResource AppMutedTextBrush}"
                           TextWrapping="Wrap"
                           Text="收敛判断: -" />
                <TextBlock x:Name="BeforeAfterStateText"
                           Margin="0,8,0,0"
                           Foreground="{DynamicResource AppMutedTextBrush}"
                           TextWrapping="Wrap"
                           Text="前后对比: -" />
                <TextBlock x:Name="DelayedTrendStateText"
                           Margin="0,8,0,0"
                           Foreground="{DynamicResource AppMutedTextBrush}"
                           TextWrapping="Wrap"
                           Text="延迟收敛: -" />
                <TextBlock x:Name="NextStepText"
                           Margin="0,8,0,0"
                           Foreground="{DynamicResource AppMutedTextBrush}"
                           TextWrapping="Wrap"
                           Text="下一步建议: -" />
                <TextBlock x:Name="AnomalyStateText"
                           Margin="0,8,0,0"
                           Foreground="{DynamicResource AppMutedTextBrush}"
                           TextWrapping="Wrap"
                           Text="异常提示: -" />
                <TextBlock x:Name="RuntimeDetailText"
                           Margin="0,8,0,0"
                           Foreground="{DynamicResource AppSubtleTextBrush}"
                           TextWrapping="Wrap" />
                <TextBlock Text="最近动作日志"
                           Margin="0,12,0,0"
                           FontWeight="SemiBold" />
                <TextBox x:Name="ActionLogText"
                         Margin="0,8,0,0"
                         Height="120"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         FontFamily="Consolas"
                         FontSize="12" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
